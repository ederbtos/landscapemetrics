# Copie este arquivo para .streamlit/secrets.toml e preencha os valores.
# NUNCA faça commit do secrets.toml real (ele já está no .gitignore).

# --- Login com Google (obrigatório) ---
# 1. Acesse https://console.cloud.google.com/apis/credentials
# 2. Configure a "OAuth consent screen" (tipo Externo/Interno, conforme seu caso).
# 3. Crie uma credencial "OAuth client ID" do tipo "Web application".
# 4. Em "Authorized redirect URIs", cadastre exatamente o valor de redirect_uri abaixo
#    (troque a URL pelo endereço real do app quando for para produção).
[auth]
redirect_uri = "http://localhost:8501/oauth2callback"
client_id = "SEU_CLIENT_ID.apps.googleusercontent.com"
client_secret = "SEU_CLIENT_SECRET"
server_metadata_url = "https://accounts.google.com/.well-known/openid-configuration"
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
cookie_secret = "GERE_UMA_STRING_ALEATORIA_AQUI"

# --- Chave de criptografia das credenciais do Earth Engine (obrigatório) ---
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Guarde essa chave em local seguro: sem ela, as credenciais salvas no banco não podem
# ser descriptografadas.
app_encryption_key = "GERE_UMA_CHAVE_FERNET_AQUI"
